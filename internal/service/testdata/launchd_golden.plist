<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Label</key>
		<string>com.agentpaas.daemon</string>
		<key>ProgramArguments</key>
		<array>
			<string>/usr/local/bin/agentpaasd</string>
			<string>--home</string>
			<string>/Users/testuser/.agentpaas</string>
		</array>
		<key>RunAtLoad</key>
		<true/>
		<key>KeepAlive</key>
		<true/>
		<key>StandardOutPath</key>
		<string>/Users/testuser/.agentpaas/logs/daemon.out.log</string>
		<key>StandardErrorPath</key>
		<string>/Users/testuser/.agentpaas/logs/daemon.err.log</string>
		<key>EnvironmentVariables</key>
		<dict>
			<key>AGENTPAAS_HOME</key>
			<string>/Users/testuser/.agentpaas</string>
		</dict>
	</dict>
</plist>
