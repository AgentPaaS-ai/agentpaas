# macOS
.DS_Store

# Landing page is a separate track, not part of the build
landing-page/

# Go build artifacts
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go coverage files
*.cover
coverage.txt

# IDE
.idea/
.vscode/
*.swp
*.swo

# AgentPaaS local state (created at runtime, never committed)
.agentpaas/
AGENTPAAS_HOME/

# Secrets and credentials — never commit
.env
.env.*
*.pem
*.key
secrets.json
credentials.json

# Local tool binaries (installed manually, not part of build)
.tools/

# Session management (not part of the codebase)
NEXT-SESSION-PROMPT.md

# Python
__pycache__/
*.pyc
t2-test-agent/

# Never commit compiled binaries
/integrations/bin/
/bin/

# Internal / private docs — not part of the public tree
docs/archive/
docs/plans/
docs/owa-records/archive/
docs/*-resume-prompt*.md
docs/*-checkpoint*.md
docs/*-block-end.md
docs/*-start-prompt.md
docs/roadmap.md
Agentpaas-pitch.md

# Execution docs: keep planning/, reference/, blocks/, current-state, README, startup prompt.
# Ignore only stale subtrees and one-off session artifacts under docs/execution/.
docs/execution/archive/
docs/execution/resume-prompts/
docs/execution/session-resume-prompt-*.md
docs/execution/testing-results.md
docs/execution/prompts/b*-restart-prompt.md
docs/execution/prompts/b*-start-prompt.md

# Ephemeral local workspaces
.worktrees/
b16-test-workspace/
