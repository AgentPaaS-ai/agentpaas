# Go source — enforce LF line endings
*.go text eol=lf

# Protocol Buffers — enforce LF line endings
*.proto text eol=lf

# Generated Go code — mark as generated for linguist
*_gen.go linguist-generated=true
*.pb.go linguist-generated=true
*_grpc.pb.go linguist-generated=true
*.pb.gw.go linguist-generated=true

# Vendored third-party — collapse in diffs by default
third_party/** linguist-vendored=true